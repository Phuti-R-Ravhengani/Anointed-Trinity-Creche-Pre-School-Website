// This is your Prisma schema file for PostgreSQL (Supabase)
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for authentication
model User {
  id              String     @id @default(cuid())
  email           String     @unique
  password        String
  role            String     @default("PARENT")
  firstName       String
  lastName        String
  phoneNumber     String?
  profileImage    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  parent          Parent?
  admin           Admin?
  sessions        Session[]
  notifications   Notification[]
  messages        Message[]

  @@index([email])
  @@index([role])
}

// Admin model
model Admin {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions String   @default("[\"all\"]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Session model for JWT
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

// Parent model
model Parent {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation      String?
  company         String?
  address         String?
  city            String?
  province        String?
  postalCode      String?
  idNumber        String?
  idType          String?
  emergencyName   String?
  emergencyPhone  String?
  emergencyEmail  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  children        Child[]
  applications    Application[]
  messages        Message[]

  @@index([userId])
}

// Child model
model Child {
  id              String   @id @default(cuid())
  parentId        String
  parent          Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          String
  allergies       String?
  medicalNotes    String?
  profileImage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  classId         String?
  class           Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)

  applications    Application[]
  attendance      Attendance[]

  @@index([parentId])
  @@index([classId])
}

// Branch model
model Branch {
  id              String   @id @default(cuid())
  name            String
  address         String
  city            String
  province        String
  postalCode      String
  country         String   @default("South Africa")
  phoneNumber     String
  email           String
  latitude        Float?
  longitude       Float?
  managerName     String?
  openingHours    String?
  numberOfClasses Int      @default(0)
  images          String   @default("[]")
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  classes         Class[]
  applications    Application[]
  
  @@index([city])
}

// Class/Grade model
model Class {
  id        String   @id @default(cuid())
  name      String
  capacity  Int      @default(30)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  students  Child[]
  @@index([branchId])
}

// Application/Admission model
model Application {
  id                  String    @id @default(cuid())
  referenceNumber     String    @unique
  parentId            String
  parent              Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  childId             String
  child               Child     @relation(fields: [childId], references: [id], onDelete: Cascade)
  branchId            String
  branch              Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  status              String    @default("PENDING")
  classPreference     String?
  startDate           DateTime?
  documents           Document[]
  notes               String?
  rejectionReason     String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  reviewedBy          String?
  reviewedAt          DateTime?

  @@index([parentId])
  @@index([childId])
  @@index([branchId])
  @@index([status])
  @@index([referenceNumber])
}

// Document model
model Document {
  id              String      @id @default(cuid())
  applicationId   String
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type            String
  url             String
  fileName        String
  fileSize        Int
  uploadedAt      DateTime    @default(now())

  @@index([applicationId])
}

// Staff model
model Staff {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  phoneNumber   String
  position      String
  qualifications String?
  dateOfBirth   DateTime
  profileImage  String?
  hireDate      DateTime
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
}

// Event model
model Event {
  id            String   @id @default(cuid())
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  location      String?
  image         String?
  category      String
  capacity      Int?
  rsvpCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  rsvps         EventRsvp[]

  @@index([startDate])
}

// Event RSVP model
model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parentId  String
  numberOfAttendees Int @default(1)
  createdAt DateTime @default(now())

  @@unique([eventId, parentId])
  @@index([eventId])
}

// Announcement model
model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  image     String?
  priority  String   @default("NORMAL")
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Gallery model
model Gallery {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  category    String
  uploadedBy  String
  uploadedAt  DateTime @default(now())

  @@index([category])
}

// Attendance model
model Attendance {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String
  notes     String?
  createdAt DateTime @default(now())

  @@unique([childId, date])
  @@index([childId])
  @@index([date])
}

// Message/Communication model
model Message {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  parentId  String
  parent    Parent   @relation(fields: [parentId], references: [id])
  subject   String
  content   String
  attachments String   @default("[]")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([senderId])
  @@index([parentId])
  @@index([read])
}

// Notification model
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

// Subscription/Newsletter model
model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  subscribed Boolean @default(true)
  createdAt DateTime @default(now())
}
